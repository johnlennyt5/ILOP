{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "/content/agent.json",
      "type": "agent",
      "uniqueId": "32160aaa-2209-4d84-a658-bc1ca2e8d2c1",
      "input": {
        "type": "object",
        "required": [
          "complianceRecord"
        ],
        "properties": {
          "complianceRecord": {
            "type": "string"
          }
        },
        "title": "Inputs"
      },
      "output": {
        "type": "object",
        "required": [
          "complianceStatus",
          "vetoCodes",
          "flagCodes",
          "checksPerformed",
          "reasoning"
        ],
        "properties": {
          "complianceStatus": {
            "type": "string",
            "description": "PASS, VETO, or FLAG. VETO if any veto code; else FLAG if any flag code; else PASS"
          },
          "vetoCodes": {
            "type": "array",
            "description": "Veto reason codes from the approved list only",
            "items": {
              "type": "string"
            }
          },
          "flagCodes": {
            "type": "array",
            "description": "Flag reason codes from the approved list only",
            "items": {
              "type": "string"
            }
          },
          "checksPerformed": {
            "type": "array",
            "description": "Names of checks executed",
            "items": {
              "type": "string"
            }
          },
          "dtiRatio": {
            "type": "number",
            "description": "Debt-to-income ratio if computable (monthly debts / monthly income), else empty"
          },
          "reasoning": {
            "type": "string",
            "description": "Concise per-check summary citing the record fields relied on"
          },
          "notes": {
            "type": "string",
            "description": "Observations or data gaps a reviewer should see"
          }
        }
      }
    }
  ]
}