          },
          "bankName": {
            "type": "string",
            "description": "Primary financial institution"
          },
          "citizenshipStatus": {
            "type": "string",
            "description": "Citizenship or residency status"
          },
          "maritalStatus": {
            "type": "string",
            "description": "Applicant marital status"
          },
          "applicationDate": {
            "type": "string",
            "description": "Loan application date"
          },
          "loanOfficer": {
            "type": "string",
            "description": "Loan officer name if present"
          },
          "applicationNumber": {
            "type": "string",
            "description": "Loan application number or reference ID"
          },
          "notes": {
            "type": "string",
            "description": "Additional underwriting notes or comments"
          },
          "missingFields": {
            "type": "array",
