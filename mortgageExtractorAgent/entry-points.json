          "propertyState": {
            "type": "string",
            "description": "State where the property is located"
          },
          "propertyZipCode": {
            "type": "string",
            "description": "ZIP code of the property"
          },
          "propertyType": {
            "type": "string",
            "description": "Property type such as Single Family, Condo, Townhouse, Duplex, Manufactured Home"
          },
          "estimatedPropertyValue": {
            "type": "number",
